<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:orientation="vertical">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="뒤로가기"
                android:src="@drawable/ic_arrow_left"
                android:tint="@color/foreground" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="운동 계획 생성"
                android:textColor="@color/foreground"
                android:textSize="24sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Preferred Days Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="선호 요일"
                    android:textColor="@color/card_foreground"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp">

                    <CheckBox
                        android:id="@+id/cb_monday"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="월요일"
                        android:textColor="@color/card_foreground"
                        android:textSize="16sp"
                        android:layout_marginBottom="4dp" />

                    <CheckBox
                        android:id="@+id/cb_tuesday"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="화요일"
                        android:textColor="@color/card_foreground"
                        android:textSize="16sp"
                        android:layout_marginBottom="4dp" />

                    <CheckBox
                        android:id="@+id/cb_wednesday"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="수요일"
                        android:textColor="@color/card_foreground"
                        android:textSize="16sp"
                        android:layout_marginBottom="4dp" />

                    <CheckBox
                        android:id="@+id/cb_thursday"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="목요일"
                        android:textColor="@color/card_foreground"
                        android:textSize="16sp"
                        android:layout_marginBottom="4dp" />

                    <CheckBox
                        android:id="@+id/cb_friday"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="금요일"
                        android:textColor="@color/card_foreground"
                        android:textSize="16sp"
                        android:layout_marginBottom="4dp" />

                    <CheckBox
                        android:id="@+id/cb_saturday"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="토요일"
                        android:textColor="@color/card_foreground"
                        android:textSize="16sp"
                        android:layout_marginBottom="4dp" />

                    <CheckBox
                        android:id="@+id/cb_sunday"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="일요일"
                        android:textColor="@color/card_foreground"
                        android:textSize="16sp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Preferred Time Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="선호 시간대"
                    android:textColor="@color/card_foreground"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <RadioGroup
                    android:id="@+id/rg_time_slots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rb_morning"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="오전 (6:00 - 12:00)"
                        android:textColor="@color/card_foreground"
                        android:textSize="16sp"
                        android:layout_marginBottom="4dp" />

                    <RadioButton
                        android:id="@+id/rb_afternoon"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="오후 (12:00 - 18:00)"
                        android:textColor="@color/card_foreground"
                        android:textSize="16sp"
                        android:layout_marginBottom="4dp" />

                    <RadioButton
                        android:id="@+id/rb_evening"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="저녁 (18:00 - 24:00)"
                        android:textColor="@color/card_foreground"
                        android:textSize="16sp" />

                </RadioGroup>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Complete Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_complete_creation"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:backgroundTint="@color/primary"
            android:enabled="false"
            android:text="선택 완료"
            android:textColor="@color/primary_foreground"
            android:textSize="16sp"
            app:cornerRadius="10dp" />

    </LinearLayout>

</ScrollView>